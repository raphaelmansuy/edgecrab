{
  "name": "edgecrab",
  "version": "0.9.0",
  "description": "Native Node.js SDK for the EdgeCrab AI agent runtime",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "edgecrab",
    "targets": [
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts",
    "wrapper.js",
    "wrapper.d.ts"
  ],
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "vitest run"
  },
  "engines": {
    "node": ">= 18"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/edgecrab/edgecrab"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "edgecrab",
    "native",
    "napi"
  ]
}
