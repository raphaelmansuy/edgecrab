# ── Rust build artefacts ─────────────────────────────────────────────────────
/target/
**/*.rs.bk

# ── Editor / OS noise ────────────────────────────────────────────────────────
*.swp
*.swo
.DS_Store
Thumbs.db
*.bak
*~
.idea/
.vscode/settings.json
.vscode/*.log

# ── Local secrets — NEVER commit ─────────────────────────────────────────────
.env
.env.local
.env.*
!.env.example
*.pem
*.key
*.p12
mcp-tokens/

# ── Edgecrab runtime state (generated at run-time, not source) ───────────────
.edgecrab/
.agent/
logs/

# ── Node.js dependencies (root + nested) ─────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Documentation site build ─────────────────────────────────────────────────
site/node_modules/
site/dist/
site/.astro/

# ── SDK build artefacts ───────────────────────────────────────────────────────
# Python SDK (embedded, maturin/PyO3)
sdks/python/dist/
sdks/python/*.egg-info/
sdks/python/.pytest_cache/
sdks/python/python/edgecrab/_native*.so
sdks/python/python/edgecrab/_native*.dylib
sdks/python/python/edgecrab/_native*.pyd
sdks/python/python/edgecrab/*.abi3.so
# Python common
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.ruff_cache/
.venv/
venv/
*.egg-info/

# Node.js / npm-cli (legacy)
sdks/node/node_modules/
sdks/node/dist/
sdks/npm-cli/node_modules/
sdks/npm-cli/dist/
# Node.js native (napi-rs)
sdks/nodejs-native/node_modules/
sdks/nodejs-native/*.node
sdks/nodejs-native/dist/
sdks/nodejs-native/.node_modules/
# WASM SDK
sdks/wasm/target/
sdks/wasm/pkg/
sdks/wasm/pkg-*/
sdks/wasm/dist/
sdks/wasm/node_modules/

# SDK Core examples compiled artefacts (in crates/edgecrab-sdk/examples)
# (these are compiled by Cargo into /target/ — already excluded above)

# SDK examples working files (data, outputs)
sdk-examples/**/__pycache__/
sdk-examples/**/*.pyc

# ── Bridge / script dependencies ─────────────────────────────────────────────
scripts/whatsapp-bridge/node_modules/
scripts/whatsapp-bridge/.baileys-store/
scripts/*/node_modules/

# ── Test artefacts ────────────────────────────────────────────────────────────
*.profraw
lcov.info
coverage/

# ── Stray / one-off files ─────────────────────────────────────────────────────
video_script.py
*.profdata
demo/
.edgecrab-artifacts/
