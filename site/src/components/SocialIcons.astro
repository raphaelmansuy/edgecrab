---
/**
 * Custom SocialIcons override for the Starlight header.
 */
---

<div class="header-nav" role="navigation" aria-label="Header navigation">
  <nav class="nav-links">
    <a href="/getting-started/quick-start/" class="nav-link">Docs</a>
    <a href="/changelog/" class="nav-link">Changelog</a>
    <a href="/contributing/" class="nav-link">Contributing</a>
  </nav>
  <div class="social-actions">
    <a
      href="https://github.com/raphaelmansuy/edgecrab"
      class="github-link"
      aria-label="View EdgeCrab on GitHub"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.92.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
      </svg>
    </a>
    <a href="/getting-started/quick-start/" class="btn-get-started">
      Get Started
    </a>
  </div>
</div>

<style>
  .header-nav {
    display: flex; align-items: center; gap: 1rem;
  }

  .nav-links {
    display: flex; align-items: center; gap: 0.125rem;
  }

  .nav-link {
    color: var(--sl-color-gray-2);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 150ms, background-color 150ms;
  }
  .nav-link:hover {
    color: var(--sl-color-accent);
    background: rgba(234, 88, 12, 0.06);
  }

  .social-actions { display: flex; align-items: center; gap: 0.75rem; }

  .github-link {
    display: flex; align-items: center;
    color: var(--sl-color-gray-2); text-decoration: none;
    padding: 0.35rem; border-radius: 0.375rem;
    transition: color 150ms;
  }
  .github-link:hover { color: var(--sl-color-accent); }

  .btn-get-started {
    display: inline-flex; align-items: center;
    background: var(--sl-color-accent, #EA580C);
    color: #fff !important;
    padding: 0.4rem 0.9rem;
    border-radius: 0.375rem;
    font-size: 0.8rem; font-weight: 600;
    text-decoration: none;
    transition: opacity 150ms;
    white-space: nowrap;
  }
  .btn-get-started:hover { opacity: 0.9; }

  @media (max-width: 720px) {
    .nav-links { display: none; }
  }
</style>
