---
interface Step {
  icon: string;
  text: string;
}

interface UseCase {
  emoji: string;
  title: string;
  scenario: string;
  steps: Step[];
  tag: string;       // e.g. "Telegram + Cron"
  tagColor?: 'orange' | 'blue' | 'green' | 'purple';
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  cases: UseCase[];
}

const { eyebrow = 'Real-World', title, subtitle, cases } = Astro.props;

const tagPalette: Record<string, string> = {
  orange: 'tag-orange',
  blue:   'tag-blue',
  green:  'tag-green',
  purple: 'tag-purple',
};
---

<section class="use-cases-section" aria-labelledby="use-cases-heading">
  <div class="uc-container">
    <span class="section-eyebrow">{eyebrow}</span>
    <h2 id="use-cases-heading" class="section-title">{title}</h2>
    <p class="section-subtitle">{subtitle}</p>

    <div class="cases-grid">
      {cases.map((uc, i) => (
        <article class="case-card" style={`--i: ${i}`}>
          <div class="case-top">
            <span class="case-emoji" aria-hidden="true">{uc.emoji}</span>
            <span class:list={['case-tag', tagPalette[uc.tagColor ?? 'orange']]}>{uc.tag}</span>
          </div>
          <h3 class="case-title">{uc.title}</h3>
          <p class="case-scenario">{uc.scenario}</p>
          <ol class="case-steps">
            {uc.steps.map((step) => (
              <li>
                <span class="step-icon" aria-hidden="true">{step.icon}</span>
                <span>{step.text}</span>
              </li>
            ))}
          </ol>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .use-cases-section {
    padding: 6rem 1.5rem;
    background: var(--sl-color-bg);
    text-align: center;
  }

  .uc-container {
    max-width: 1060px;
    margin: 0 auto;
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--sl-color-accent);
    margin-bottom: 0.75rem; padding: 0.3rem 0.75rem;
    background: rgba(234, 88, 12, 0.08); border-radius: 999px;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800;
    margin-bottom: 0.75rem; color: var(--ep-text-primary, #111827);
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem; color: var(--ep-text-secondary, #6B7280);
    max-width: 600px; margin: 0 auto 3.5rem; line-height: 1.6;
  }

  /* ── Grid ── */
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    text-align: left;
  }

  @media (max-width: 900px) {
    .cases-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .cases-grid { grid-template-columns: 1fr; }
  }

  /* ── Card ── */
  .case-card {
    background: var(--ep-card-bg, #fff);
    border: 1px solid var(--ep-card-border, #E5E7EB);
    border-radius: 1rem;
    padding: 1.5rem 1.75rem;
    box-shadow: var(--ep-card-shadow);
    display: flex; flex-direction: column; gap: 0.875rem;
    animation: fadeInUp 0.5s ease both;
    animation-delay: calc(var(--i, 0) * 0.08s);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .case-card:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,0.09);
    transform: translateY(-2px);
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Card top row ── */
  .case-top {
    display: flex; justify-content: space-between; align-items: center;
  }

  .case-emoji {
    font-size: 1.75rem; line-height: 1;
  }

  .case-tag {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.07em; padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }

  .tag-orange { background: rgba(234, 88, 12, 0.1);  color: #C2410C; }
  .tag-blue   { background: rgba(37, 99, 235, 0.1);  color: #1D4ED8; }
  .tag-green  { background: rgba(22, 163, 74, 0.1);  color: #15803D; }
  .tag-purple { background: rgba(124, 58, 237, 0.1); color: #6D28D9; }

  [data-theme='dark'] .tag-orange { background: rgba(234, 88, 12, 0.2);  color: #FB923C; }
  [data-theme='dark'] .tag-blue   { background: rgba(37, 99, 235, 0.2);  color: #93C5FD; }
  [data-theme='dark'] .tag-green  { background: rgba(22, 163, 74, 0.2);  color: #86EFAC; }
  [data-theme='dark'] .tag-purple { background: rgba(124, 58, 237, 0.2); color: #C4B5FD; }

  /* ── Title + scenario ── */
  .case-title {
    font-size: 1rem; font-weight: 800;
    color: var(--ep-text-primary, #111827);
    margin: 0; line-height: 1.3;
  }

  .case-scenario {
    font-size: 0.875rem; line-height: 1.6;
    color: var(--ep-text-secondary, #4B5563);
    margin: 0;
  }

  /* ── Steps ── */
  .case-steps {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 0.45rem;
    margin-top: auto;
    border-top: 1px solid var(--ep-card-border, #E5E7EB);
    padding-top: 0.875rem;
  }

  .case-steps li {
    display: flex; align-items: flex-start; gap: 0.5rem;
    font-size: 0.82rem; line-height: 1.5;
    color: var(--ep-text-primary, #374151);
    counter-increment: none;
  }

  .step-icon {
    font-size: 0.9rem;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  /* ── Dark mode ── */
  [data-theme='dark'] .case-card {
    background: var(--ep-card-bg, #1F2937);
    border-color: var(--ep-card-border, #374151);
  }

  [data-theme='dark'] .case-steps {
    border-top-color: var(--ep-card-border, #374151);
  }

  @media (max-width: 540px) {
    .use-cases-section { padding: 4rem 1rem; }
    .case-card { padding: 1.25rem; }
  }
</style>
