---
interface Props {
  title: string;
  subtitle: string;
  installCmd: string;
  primaryHref: string;
  primaryText: string;
  secondaryHref: string;
  secondaryText: string;
}

const { title, subtitle, installCmd, primaryHref, primaryText, secondaryHref, secondaryText } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="cta-section" aria-labelledby="cta-heading">
  <h2 id="cta-heading" class="cta-title">{title}</h2>
  <p class="cta-subtitle">{subtitle}</p>

  <div class="cta-install">
    <code>{installCmd}</code>
  </div>

  <div class="cta-actions">
    <a
      href={primaryHref.startsWith('/docs/') ? `${base}${primaryHref.replace(/^\/docs\//, '')}` : primaryHref}
      class="btn-primary"
    >
      {primaryText}
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>
    <a href={secondaryHref} target="_blank" rel="noopener noreferrer" class="btn-secondary">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="16" height="16" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
      </svg>
      {secondaryText}
    </a>
  </div>
</section>

<style>
  .cta-section {
    padding: 5rem 1.5rem;
    text-align: center;
    background: var(--ep-hero-gradient);
    border-top: 1px solid var(--ep-card-border, #E5E7EB);
  }

  .cta-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 800; margin-bottom: 1rem;
    color: var(--ep-text-primary, #111827);
    letter-spacing: -0.02em;
  }

  .cta-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.125rem);
    color: var(--ep-text-secondary, #4B5563);
    max-width: 500px; margin: 0 auto 2rem; line-height: 1.6;
  }

  .cta-install {
    display: inline-block;
    background: var(--ep-code-bg, #F3F4F6);
    border: 1px solid var(--ep-card-border, #E5E7EB);
    border-radius: 0.75rem;
    padding: 0.75rem 1.5rem; margin-bottom: 2rem;
    font-family: var(--ep-font-mono, monospace); font-size: 0.9rem;
    color: var(--ep-text-primary);
  }

  .cta-actions {
    display: flex; flex-wrap: wrap; gap: 0.75rem;
    justify-content: center;
  }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--sl-color-accent, #EA580C); color: #fff !important;
    padding: 0.7rem 1.4rem; border-radius: 0.5rem;
    font-weight: 600; font-size: 0.95rem; text-decoration: none;
    transition: opacity 150ms, transform 150ms;
  }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }

  .btn-secondary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--ep-card-bg, #fff);
    color: var(--ep-text-primary, #111827) !important;
    border: 1px solid var(--ep-card-border, #E5E7EB);
    padding: 0.7rem 1.4rem; border-radius: 0.5rem;
    font-weight: 600; font-size: 0.95rem; text-decoration: none;
    transition: border-color 150ms, box-shadow 150ms;
  }
  .btn-secondary:hover { border-color: var(--sl-color-accent); box-shadow: 0 0 0 3px rgba(234,88,12,0.08); }
</style>
