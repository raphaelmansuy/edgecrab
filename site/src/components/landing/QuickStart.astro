---
interface Tab {
  label: string;
  lang: string;
  code: string;
}

interface Props {
  title: string;
  subtitle: string;
  tabs: Tab[];
}

const { title, subtitle, tabs } = Astro.props;
---

<section class="quickstart-section" aria-labelledby="quickstart-heading">
  <h2 id="quickstart-heading" class="section-title">{title}</h2>
  <p class="section-subtitle">{subtitle}</p>

  <div class="quickstart-tabs" data-tabs>
    <div class="tab-bar" role="tablist">
      {tabs.map((tab, i) => (
        <button
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          data-tab-index={i}
          class:list={['tab-btn', { active: i === 0 }]}
        >
          <span class="tab-dot" aria-hidden="true"></span>
          {tab.label}
        </button>
      ))}
    </div>

    {tabs.map((tab, i) => (
      <div
        role="tabpanel"
        data-panel-index={i}
        class:list={['tab-panel', { active: i === 0 }]}
      >
        <pre><code class={`language-${tab.lang}`} set:text={tab.code.trim()} /></pre>
      </div>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll('[data-tabs]').forEach(container => {
    const buttons = container.querySelectorAll('[role="tab"]');
    const panels = container.querySelectorAll('[role="tabpanel"]');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const index = (btn as HTMLElement).dataset.tabIndex;
        buttons.forEach(b => { b.setAttribute('aria-selected', 'false'); b.classList.remove('active'); });
        panels.forEach(p => p.classList.remove('active'));
        btn.setAttribute('aria-selected', 'true');
        btn.classList.add('active');
        container.querySelector(`[data-panel-index="${index}"]`)?.classList.add('active');
      });
    });
  });
</script>

<style>
  .quickstart-section {
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    margin-bottom: 0.75rem;
    color: var(--ep-text-primary, #111827);
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.125rem);
    color: var(--ec-color-muted, #6B7280);
    max-width: 560px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .quickstart-tabs {
    max-width: 760px;
    margin: 0 auto;
    text-align: left;
    border: 1px solid var(--ep-card-border, #E5E7EB);
    border-radius: 1rem;
    overflow: hidden;
    background: var(--ep-card-bg, white);
    box-shadow: var(--ep-card-shadow);
  }

  .tab-bar {
    display: flex;
    background: var(--ep-section-alt-bg, #F9FAFB);
    border-bottom: 1px solid var(--ep-card-border, #E5E7EB);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .tab-bar::-webkit-scrollbar { display: none; }

  .tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ec-color-muted, #6B7280);
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 150ms, border-color 150ms;
  }

  .tab-btn:hover { color: var(--ep-text-primary, #111827); }

  .tab-btn.active {
    color: var(--sl-color-accent, #EA580C);
    border-bottom-color: var(--sl-color-accent, #EA580C);
  }

  .tab-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.6;
  }

  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .tab-panel pre {
    margin: 0;
    padding: 1.5rem;
    background: var(--ep-card-bg, #fff);
    overflow-x: auto;
  }

  .tab-panel code {
    font-family: var(--ep-font-mono, monospace);
    font-size: 0.82rem;
    line-height: 1.65;
    color: var(--ep-text-primary, #111827);
    white-space: pre;
  }

  @media (max-width: 540px) {
    .quickstart-section { padding: 3rem 1rem; }
  }
</style>
