  'box': 'M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9',
  'refresh': 'M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99',
};
---

<section class="feature-section" aria-labelledby="feature-heading">
  <div class="feature-container">
    <div class="feature-header">
      <span class="feature-eyebrow">Features</span>
      <h2 id="feature-heading" class="section-title">{title}</h2>
      <p class="section-subtitle">{subtitle}</p>
    </div>
    <div class="feature-grid">
      {features.map((f, i) => (
        <div class="feature-card" style={`--delay: ${i * 0.05}s`}>
          <div class="feature-icon-wrap">
            <svg class="feature-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={svgPaths[f.icon] || svgPaths['zap']} />
            </svg>
          </div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-section {
    padding: 6rem 1.5rem;
    background: var(--ep-section-alt-bg, #F9FAFB);
    text-align: center;
  }

  .feature-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .feature-header {
    margin-bottom: 3.5rem;
  }

  .feature-eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sl-color-accent, #EA580C);
    margin-bottom: 0.75rem;
    padding: 0.3rem 0.75rem;
    background: rgba(234, 88, 12, 0.08);
    border-radius: 999px;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 0.75rem;
    color: var(--ep-text-primary, #111827);
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--ep-text-secondary, #6B7280);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .feature-card {
    background: var(--ep-card-bg, #FFFFFF);
    border: 1px solid var(--ep-card-border, #E5E7EB);
    border-radius: 0.875rem;
    padding: 1.75rem 1.5rem;
    text-align: left;
    transition: box-shadow 200ms ease, transform 200ms ease;
    animation: fadeInUp 0.4s ease-out both;
    animation-delay: var(--delay, 0s);
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .feature-card:hover {
    box-shadow: var(--ep-card-shadow-hover);
    transform: translateY(-2px);
  }

  .feature-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background: rgba(234, 88, 12, 0.08);
    border-radius: 0.625rem;
    margin-bottom: 1rem;
    color: var(--sl-color-accent, #EA580C);
  }

  .feature-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ep-text-primary, #111827);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .feature-desc {
    font-size: 0.875rem;
    color: var(--ep-text-secondary, #6B7280);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 900px) {
    .feature-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .feature-grid { grid-template-columns: 1fr; }
    .feature-section { padding: 4rem 1rem; }
  }
</style>
