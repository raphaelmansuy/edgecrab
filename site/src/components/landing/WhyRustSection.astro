---
interface Panel {
  tag: string;        // e.g. "vs. hermes-agent"
  headline: string;
  body: string;
  wins: string[];     // bullet points — EdgeCrab leads here
  honest: string;     // honest caveat about competitor's strength
  icon: string;       // 'brain' | 'bolt' | 'merge'
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  panels: Panel[];
}

const { eyebrow = 'Why Rust?', title, subtitle, panels } = Astro.props;

const icons: Record<string, string> = {
  brain: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a5 5 0 0 1 5 5c0 1.5-.7 2.9-1.7 3.8A5 5 0 0 1 17 15a5 5 0 0 1-5 5 5 5 0 0 1-5-5 5 5 0 0 1 1.7-3.2A5 5 0 0 1 7 7a5 5 0 0 1 5-5Z"/><line x1="12" y1="2" x2="12" y2="22"/></svg>`,
  bolt: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  merge: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 9v12"/><path d="M18 9c0-4.97-4.03-9-9-9"/></svg>`,
};
---

<section class="why-rust-section" aria-labelledby="why-rust-heading">
  <div class="why-rust-container">
    <span class="section-eyebrow">{eyebrow}</span>
    <h2 id="why-rust-heading" class="section-title">{title}</h2>
    <p class="section-subtitle">{subtitle}</p>

    <div class="panels">
      {panels.map((panel) => (
        <div class="panel">
          <div class="panel-header">
            <span class="panel-icon" set:html={icons[panel.icon] ?? icons.bolt} />
            <div>
              <span class="panel-tag">{panel.tag}</span>
              <h3 class="panel-headline">{panel.headline}</h3>
            </div>
          </div>
          <p class="panel-body">{panel.body}</p>

          <ul class="panel-wins">
            {panel.wins.map((win) => (
              <li>
                <span class="win-dot" aria-hidden="true">✦</span>
                <span>{win}</span>
              </li>
            ))}
          </ul>

          <div class="panel-honest" role="note">
            <span class="honest-label">Honest take:</span>
            {panel.honest}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why-rust-section {
    padding: 6rem 1.5rem;
    background: var(--ep-section-alt-bg, #F9FAFB);
    text-align: center;
  }

  .why-rust-container {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--sl-color-accent);
    margin-bottom: 0.75rem; padding: 0.3rem 0.75rem;
    background: rgba(234, 88, 12, 0.08); border-radius: 999px;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800;
    margin-bottom: 0.75rem; color: var(--ep-text-primary, #111827);
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem; color: var(--ep-text-secondary, #6B7280);
    max-width: 600px; margin: 0 auto 3.5rem; line-height: 1.6;
  }

  /* ── Panels ── */
  .panels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    text-align: left;
  }

  @media (max-width: 860px) {
    .panels { grid-template-columns: 1fr; max-width: 560px; margin: 0 auto; }
  }

  .panel {
    background: var(--ep-card-bg, #fff);
    border: 1px solid var(--ep-card-border, #E5E7EB);
    border-radius: 1rem;
    padding: 1.75rem;
    box-shadow: var(--ep-card-shadow);
    display: flex; flex-direction: column; gap: 1rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .panel:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }

  /* ── Panel header ── */
  .panel-header {
    display: flex; align-items: flex-start; gap: 0.875rem;
  }

  .panel-icon {
    color: var(--sl-color-accent);
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .panel-tag {
    display: inline-block;
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ep-text-secondary, #6B7280);
    margin-bottom: 0.3rem;
  }

  .panel-headline {
    font-size: 1.05rem; font-weight: 800;
    color: var(--ep-text-primary, #111827);
    margin: 0; line-height: 1.3;
  }

  /* ── Body ── */
  .panel-body {
    font-size: 0.9rem; line-height: 1.65;
    color: var(--ep-text-secondary, #4B5563);
    margin: 0;
  }

  /* ── Wins list ── */
  .panel-wins {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 0.5rem;
  }

  .panel-wins li {
    display: flex; align-items: flex-start; gap: 0.5rem;
    font-size: 0.875rem; line-height: 1.5;
    color: var(--ep-text-primary, #111827);
  }

  .win-dot {
    color: var(--sl-color-accent);
    font-size: 0.7rem;
    margin-top: 0.35rem;
    flex-shrink: 0;
  }

  /* ── Honest take ── */
  .panel-honest {
    font-size: 0.8rem; line-height: 1.55;
    color: var(--ep-text-secondary, #6B7280);
    border-top: 1px solid var(--ep-card-border, #E5E7EB);
    padding-top: 0.875rem;
    margin-top: auto;
    font-style: italic;
  }

  .honest-label {
    font-weight: 700; font-style: normal;
    color: var(--ep-text-primary, #374151);
    margin-right: 0.25rem;
  }

  /* ── Dark mode ── */
  [data-theme='dark'] .panel {
    background: var(--ep-card-bg, #1F2937);
    border-color: var(--ep-card-border, #374151);
  }

  [data-theme='dark'] .panel-honest {
    border-top-color: var(--ep-card-border, #374151);
  }

  @media (max-width: 540px) {
    .why-rust-section { padding: 4rem 1rem; }
    .panel { padding: 1.25rem; }
  }
</style>
